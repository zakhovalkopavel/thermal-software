# ==========================================
# Environment Configuration
# ==========================================
# This file contains ALL configuration values
# NO defaults in Docker files or compose.yml
# Copy this to .env and customize values

# ==========================================
# Application
# ==========================================
NODE_ENV=development
APP_VERSION=2.0.0-dev
API_VERSION=v1

# ==========================================
# Legacy System
# ==========================================
LEGACY_PORT=18080
LEGACY_VERSION=1.0.0

# ==========================================
# Database - PostgreSQL
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=thermal
DB_PASSWORD=CHANGE_THIS_IN_PRODUCTION
DB_DATABASE=thermal

# ==========================================
# Cache - Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# JWT Secrets
# ==========================================
# ⚠️ CHANGE THESE IN PRODUCTION!
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_SECRET_IN_PRODUCTION_USE_OPENSSL_RAND
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_IN_PRODUCTION
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Ports Configuration
# ==========================================
# HTTP/HTTPS (Nginx)
HTTP_PORT=80
HTTPS_PORT=443

# Backend (internal)
BACKEND_PORT=4000

# Frontend (internal - nginx serves this)
FRONTEND_PORT=80

# Vite dev server (development only)
VITE_PORT=5173

# ==========================================
# API Configuration
# ==========================================
# Internal API URL (backend to backend)
API_URL=http://backend:4000/api/v1

# Frontend API URL (via Nginx proxy)
VITE_API_URL=/api/v1

# CORS Configuration
CORS_ORIGIN=*

# ==========================================
# Docker Image Versions
# ==========================================
# Verified: February 1, 2026
POSTGRES_VERSION=18.1-alpine
REDIS_VERSION=8.4-alpine
NODE_VERSION=24.13.0-alpine
NGINX_VERSION=1.28.1-alpine
PYTHON_VERSION=3.14.2-alpine

# ==========================================
# Docker Registry (for build and push)
# ==========================================
# Registry URL (docker.io for Docker Hub)
DOCKER_REGISTRY=docker.io

# Your Docker Hub username or private registry username
DOCKER_USERNAME=yourusername

# Docker password/token (optional - will prompt if not set)
# For Docker Hub, use access token (not password)
# Generate at: https://hub.docker.com/settings/security
# DOCKER_PASSWORD=your_access_token_here

# Image prefix (organization/project name)
IMAGE_PREFIX=thermal

# Version tag (auto-generated if not set: YYYYMMDD-HHMMSS)
# VERSION=1.0.0

