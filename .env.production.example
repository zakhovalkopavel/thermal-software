# ==========================================
# Production Environment Configuration
# ==========================================
# ⚠️ CRITICAL: This is a PRODUCTION configuration template
#
# Instructions:
# 1. Copy this file to .env on production server
# 2. Generate secure secrets (see commands below)
# 3. Update all CHANGE_THIS values
# 4. NEVER commit .env to git
# 5. Restrict file permissions: chmod 600 .env

# ==========================================
# Application
# ==========================================
NODE_ENV=production
APP_VERSION=2.0.0
API_VERSION=v1

# ==========================================
# Legacy System
# ==========================================
LEGACY_PORT=18080
LEGACY_VERSION=1.0.0

# ==========================================
# Database - PostgreSQL
# ==========================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=thermal_prod
# ⚠️ Generate with: openssl rand -base64 32
DB_PASSWORD=CHANGE_THIS_GENERATE_SECURE_PASSWORD
DB_DATABASE=thermal_production

# ==========================================
# Cache - Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# JWT Secrets
# ==========================================
# ⚠️ CRITICAL: Generate with: openssl rand -base64 32
# Run on production server:
#   docker run --rm alpine/openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_GENERATE_WITH_OPENSSL_RAND_BASE64_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_GENERATE_DIFFERENT_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Ports Configuration
# ==========================================
# HTTP/HTTPS (Nginx - public facing)
HTTP_PORT=80
HTTPS_PORT=443

# Backend (internal only - not exposed to internet)
BACKEND_PORT=4000

# Frontend (internal only - served by nginx)
FRONTEND_PORT=80

# ==========================================
# API Configuration
# ==========================================
# Internal API URL (backend to backend communication)
API_URL=http://backend:4000/api/v1

# Frontend API URL (via Nginx proxy)
# Use relative path so it works with your domain
VITE_API_URL=/api/v1

# CORS Configuration
# ⚠️ CHANGE THIS: Set to your production domain
# Example: CORS_ORIGIN=https://yourdomain.com
CORS_ORIGIN=CHANGE_THIS_TO_YOUR_DOMAIN

# ==========================================
# Docker Image Versions
# ==========================================
# Verified: February 1, 2026
# Use specific versions (not :latest) for production stability
POSTGRES_VERSION=18.1-alpine
REDIS_VERSION=8.4-alpine
NODE_VERSION=24.13.0-alpine
NGINX_VERSION=1.28.1-alpine
PYTHON_VERSION=3.14.2-alpine

# ==========================================
# Docker Registry (for deployment)
# ==========================================
# Your private registry or Docker Hub
DOCKER_REGISTRY=docker.io

# Organization/username
DOCKER_USERNAME=CHANGE_THIS_YOUR_DOCKER_USERNAME

# Access token (DO NOT use password)
# Generate at: https://hub.docker.com/settings/security
DOCKER_PASSWORD=CHANGE_THIS_YOUR_DOCKER_ACCESS_TOKEN

# Image prefix (your organization/project name)
IMAGE_PREFIX=thermal

# Version tag for production deployment
VERSION=2.0.0

# ==========================================
# SSL/TLS Configuration (Optional)
# ==========================================
# If using SSL certificates, place them in docker/nginx/ssl/
# and update nginx configuration
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ==========================================
# Logging & Monitoring (Optional)
# ==========================================
# Log level: error, warn, info, debug
LOG_LEVEL=warn

# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ==========================================
# Email Configuration (Optional)
# ==========================================
# SMTP for sending emails
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASSWORD=CHANGE_THIS_SMTP_PASSWORD
# SMTP_FROM=noreply@yourdomain.com

# ==========================================
# Backup Configuration (Optional)
# ==========================================
# S3 or cloud storage for backups
# BACKUP_ENABLED=true
# S3_BUCKET=your-backup-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=CHANGE_THIS_S3_ACCESS_KEY
# S3_SECRET_KEY=CHANGE_THIS_S3_SECRET_KEY

# ==========================================
# PRODUCTION SECURITY CHECKLIST
# ==========================================
# Before deploying to production, ensure:
#
# ✅ All CHANGE_THIS values are replaced with real values
# ✅ JWT_SECRET and JWT_REFRESH_SECRET are unique, random, 32+ characters
# ✅ DB_PASSWORD is strong and unique
# ✅ CORS_ORIGIN is set to your actual domain (not *)
# ✅ NODE_ENV is set to 'production'
# ✅ SSL certificates are configured (HTTPS)
# ✅ File permissions: chmod 600 .env (only owner can read)
# ✅ .env is NOT committed to git (.gitignore includes it)
# ✅ Firewall configured (only 80/443 exposed externally)
# ✅ Database backups are configured
# ✅ Monitoring/logging is set up (Sentry, CloudWatch, etc.)
#
# Generate secrets on production server:
#   docker run --rm alpine/openssl rand -base64 32
#
# Or use the helper script:
#   ./scripts/generate-production-secrets.sh

